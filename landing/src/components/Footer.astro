---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <img src="/logo.png" alt="" width="22" height="22" />
      <span>Recall</span>
    </div>

    <div class="footer__links">
      <a
        href="https://github.com/piyushpradhan/recall"
        target="_blank"
        rel="noopener noreferrer">GitHub</a
      >
      <a
        href="https://github.com/piyushpradhan/recall/releases"
        target="_blank"
        rel="noopener noreferrer">Releases</a
      >
      <a
        href="https://github.com/piyushpradhan/recall/issues"
        target="_blank"
        rel="noopener noreferrer">Issues</a
      >
      <a
        href="https://github.com/piyushpradhan/recall/blob/main/README.md"
        target="_blank"
        rel="noopener noreferrer">README</a
      >
    </div>

    <p class="footer__fine">© {year} Recall · MIT licensed · Built with Tauri</p>
  </div>
</footer>

<style>
  .footer {
    padding: 40px 0 60px;
    border-top: 1px solid var(--border-soft);
    margin-top: 40px;
  }

  .footer__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    text-align: center;
  }

  .footer__brand {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    color: var(--fg);
  }

  .footer__links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
    color: var(--fg-muted);
    font-size: 13.5px;
  }

  .footer__links a {
    transition: color 150ms ease;
  }

  .footer__links a:hover {
    color: var(--accent-ink);
  }

  .footer__fine {
    font-family: var(--font-mono);
    font-size: 11.5px;
    color: var(--fg-faint);
    letter-spacing: 0.02em;
  }
</style>
