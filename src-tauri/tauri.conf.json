{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Recall",
  "version": "0.5.0",
  "identifier": "com.getrecall.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "library",
        "title": "Recall",
        "width": 1080,
        "height": 720,
        "minWidth": 820,
        "minHeight": 520,
        "decorations": false,
        "transparent": true,
        "center": true,
        "windowEffects": {
          "effects": ["mica"],
          "state": "active"
        }
      },
      {
        "label": "palette",
        "title": "Recall Palette",
        "url": "index.html?window=palette",
        "width": 720,
        "height": 520,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "center": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self' https://api.openai.com https://api.anthropic.com https://*.anthropic.com http://localhost:* https://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
